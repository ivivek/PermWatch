# Copy this to keystore.properties (gitignored) and fill in real values.
#
# Generate the upload keystore once with:
#
#   /opt/jbr/bin/keytool -genkey -v \
#     -keystore ~/keystores/permission-alerts-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Back up the resulting .jks and the passwords somewhere safe — losing them
# means you can't sign updates to the same Play Store listing.

storeFile=/home/vibe/keystores/permission-alerts-upload.jks
storePassword=CHANGEME
keyAlias=upload
keyPassword=CHANGEME
