<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Iridescent ring: outer disc with sweep gradient -->
    <path android:pathData="M22,54 a32,32 0 1,0 64,0 a32,32 0 1,0 -64,0 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="sweep"
                android:centerX="54"
                android:centerY="54">
                <item android:offset="0.00" android:color="#8F8CFF" />
                <item android:offset="0.33" android:color="#00CDAA" />
                <item android:offset="0.66" android:color="#F960CF" />
                <item android:offset="1.00" android:color="#8F8CFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Pupil: dark inset disc -->
    <path
        android:fillColor="#01010E"
        android:pathData="M32,54 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 z" />

    <!-- Centre: bright ink dot with soft halo -->
    <path android:pathData="M42,54 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="14">
                <item android:offset="0.00" android:color="#FFFFFFFF" />
                <item android:offset="0.65" android:color="#FFECF2FF" />
                <item android:offset="1.00" android:color="#80ECF2FF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
