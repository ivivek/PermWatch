<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="64dp"
    android:height="64dp"
    android:viewportWidth="64"
    android:viewportHeight="64">

    <!-- Rounded square dark bg -->
    <path
        android:fillColor="#01010E"
        android:pathData="M12,0 L52,0 A12,12 0 0,1 64,12 L64,52 A12,12 0 0,1 52,64 L12,64 A12,12 0 0,1 0,52 L0,12 A12,12 0 0,1 12,0 Z" />

    <!-- Iridescent ring -->
    <path android:pathData="M10,32 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="sweep"
                android:centerX="32"
                android:centerY="32">
                <item android:offset="0.00" android:color="#8F8CFF" />
                <item android:offset="0.33" android:color="#00CDAA" />
                <item android:offset="0.66" android:color="#F960CF" />
                <item android:offset="1.00" android:color="#8F8CFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Pupil -->
    <path
        android:fillColor="#01010E"
        android:pathData="M17,32 a15,15 0 1,0 30,0 a15,15 0 1,0 -30,0 z" />

    <!-- Centre with halo -->
    <path android:pathData="M24,32 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32"
                android:centerY="32"
                android:gradientRadius="10">
                <item android:offset="0.00" android:color="#FFFFFFFF" />
                <item android:offset="0.65" android:color="#FFECF2FF" />
                <item android:offset="1.00" android:color="#80ECF2FF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
